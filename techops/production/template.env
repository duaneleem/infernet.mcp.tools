# infernet.mcp.tools — MCP tool environment (production stack)
#
# Local workflow: copy this file to `.env` in this directory, then fill in values.
#   cp template.env .env
# In CI/Kubernetes, inject the same variable names via secrets—do not commit real values.
# This `template.env` is safe to commit; never commit `techops/production/.env`.

# -----------------------------------------------------------------------------
# mcpo gateway (Docker entrypoint) — https://github.com/open-webui/mcpo
# -----------------------------------------------------------------------------
# Published host port (Compose maps host:container as MCPO_PUBLISH_PORT:8000).
MCPO_PUBLISH_PORT=8000
# Listen port inside the container (fixed at 8000 by docker-compose; do not change
# unless you also change the compose "ports" target and the healthcheck URL).
MCPO_PORT=8000
# Optional: require this value as X-API-Key (or Authorization) on HTTP requests
# MCPO_API_KEY=
# Set to 1 or true to protect /docs and OpenAPI with the API key as well
# MCPO_STRICT_AUTH=

# -----------------------------------------------------------------------------
# Trello MCP — https://github.com/delorenj/mcp-server-trello
# Required: API key from https://trello.com/app-key and a user token with scopes.
# -----------------------------------------------------------------------------
TRELLO_API_KEY=
TRELLO_TOKEN=

# Optional defaults (see upstream README / example.env)
# TRELLO_WORKSPACE_ID=
# TRELLO_BOARD_ID=

# -----------------------------------------------------------------------------
# Context7 MCP — https://github.com/upstash/context7
# Required for authenticated usage: create a key at https://context7.com/dashboard
# -----------------------------------------------------------------------------
CONTEXT7_API_KEY=

# -----------------------------------------------------------------------------
# Playwright MCP — https://github.com/microsoft/playwright-mcp
# No API keys. Configuration uses PLAYWRIGHT_MCP_* (maps to CLI flags); see upstream.
# -----------------------------------------------------------------------------
# PLAYWRIGHT_MCP_BROWSER=chromium
# PLAYWRIGHT_MCP_HEADLESS=true
